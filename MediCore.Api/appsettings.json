{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=medicore.db"
  },
  "Jwt": {
    "Issuer": "MediCore.Api",
    "Audience": "MediCore.Client",
    "ExpiryMinutes": 120
  },
  "SlotGeneration": {
    "GiorniFinestra": 60
  },
  "FileStorage": {
    "LocalPath": "App_Data/Referti"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
