{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=medicore.db"
  },
  "Jwt": {
    "Issuer": "MediCore.Api",
    "Audience": "MediCore.Client",
    "ExpiryMinutes": 120
  },
  "SlotGeneration": {
    "GiorniFinestra": 60
  },
  "DemoData": {
    "Enabled": false
  },
  "Notifiche": {
    "FinestraPromemoriaOre": 24,
    "IntervalloScansioneMinuti": 15
  },
  "FileStorage": {
    "LocalPath": "App_Data/Referti"
  },
  "Mistral": {
    "BaseUrl": "https://api.mistral.ai",
    "Model": "mistral-large-latest",
    "TimeoutSeconds": 30
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
